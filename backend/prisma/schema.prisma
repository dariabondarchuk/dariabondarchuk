generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DPO
  EMPLOYEE
}

enum ProcessStatus {
  NOT_SENT
  SENT
  FILLING
  REVIEW
  ACCEPTED
  RETURNED
  NEED_CHECK
  VERIFIED
}

enum SectionStatus {
  NOT_FILLED
  FILLING
  FILLED
}

enum JournalType {
  SUBJECT
  RKN
}

enum JournalStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  CLOSED
}

enum RknStatus {
  SUBMITTED
  NOT_SUBMITTED
  NEEDS_UPDATE
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name      String
  role      Role       @default(EMPLOYEE)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  auditLogs AuditLog[]
}

model Company {
  id             Int                  @id @default(autoincrement())
  name           String
  shortName      String?
  inn            String               @unique
  ogrn           String?
  okved          String?
  activityType   String?
  ceoName        String?
  ceoPosition    String?
  phone          String?
  email          String?
  legalAddress   String?
  postalAddress  String?
  city           String?
  pdStartDate    DateTime?
  isOperator     Boolean              @default(false)
  hasCrossBorder Boolean              @default(false)
  hasDirectories Boolean              @default(false)
  contactEmail   String?
  offices        Json                 @default("[]")
  sites          Json                 @default("[]")
  apps           Json                 @default("[]")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  processes         Process[]
  responsibles      CompanyResponsible[]
  rknNotifications  RknNotification[]
  journalEntries    JournalEntry[]
  monitorEvents     MonitorEvent[]
  generatedDocuments GeneratedDocument[]
  anketaInvites      AnketaInvite[]
}

model CompanyResponsible {
  id                 Int     @id @default(autoincrement())
  companyId          Int
  company            Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role               String  @default("organizer")
  fio                String?
  position           String?
  email              String?
  phone              String?
  isSecurity         Boolean @default(false)
  controlsCompliance Boolean @default(false)
  informsEmployees   Boolean @default(false)
  handlesRequests    Boolean @default(false)
}

model Process {
  id        Int           @id @default(autoincrement())
  companyId Int
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  tags      String[]
  status    ProcessStatus @default(NOT_SENT)
  sentTo    String?
  sentAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sections  ProcessSection[]
  invites   ProcessInvite[]
  anketaType String?
  sourceInvites AnketaInvite[]
}

model AnketaInvite {
  id          Int       @id @default(autoincrement())
  companyId   Int
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  anketaType  String
  token       String    @unique
  email       String?
  comment     String?
  data        Json      @default("{}")
  expiresAt   DateTime?
  submittedAt DateTime?
  processId   Int?
  process     Process?  @relation(fields: [processId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
}

model ProcessInvite {
  id          Int       @id @default(autoincrement())
  processId   Int
  process     Process   @relation(fields: [processId], references: [id], onDelete: Cascade)
  token       String    @unique
  email       String?
  comment     String?
  expiresAt   DateTime?
  submittedAt DateTime?
  createdAt   DateTime  @default(now())
}

model ProcessSection {
  id            Int           @id @default(autoincrement())
  processId     Int
  process       Process       @relation(fields: [processId], references: [id], onDelete: Cascade)
  sectionNumber Int
  sectionName   String
  status        SectionStatus @default(NOT_FILLED)
  data          Json          @default("{}")

  @@unique([processId, sectionNumber])
}

model RknNotification {
  id         Int           @id @default(autoincrement())
  companyId  Int
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status     RknStatus     @default(NOT_SUBMITTED)
  submitDate DateTime?
  changeDate DateTime?
  documents  RknDocument[]
}

model RknDocument {
  id             Int             @id @default(autoincrement())
  notificationId Int
  notification   RknNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  fileName       String
  filePath       String
  uploadDate     DateTime        @default(now())
  isCurrent      Boolean         @default(true)
  version        Int             @default(1)
}

model JournalEntry {
  id          Int           @id @default(autoincrement())
  companyId   Int
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        JournalType
  dateIn      DateTime
  dateOut     DateTime?
  sender      String
  content     String
  contentFile String?
  answer      String?
  answerFile       String?
  additionalFiles  Json          @default("[]")
  status           JournalStatus @default(NEW)
  createdAt        DateTime      @default(now())
}

model MonitorEvent {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  eventDate DateTime @default(now())
  eventType String
  oldValue  String?
  newValue  String?
  isRead    Boolean  @default(false)
}

model GeneratedDocument {
  id         Int       @id @default(autoincrement())
  companyId  Int
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  type       String
  filePath   String?
  uploadDate DateTime?
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])
  entityType String
  entityId   Int
  action     String
  changes    Json     @default("{}")
  ipAddress  String?
  createdAt  DateTime @default(now())
}
