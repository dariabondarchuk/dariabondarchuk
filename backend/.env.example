DATABASE_URL="postgresql://pdn_user:your_secure_password@localhost:5432/pdn_registry"
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
PORT=4000
UPLOAD_DIR="./uploads"
PUBLIC_URL="http://localhost:5173"

# SMTP — локально: docker compose up -d mailpit (веб-интерфейс http://localhost:8025)
# Продакшен: smtp.yandex.ru / корпоративный сервер
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@samolet.ru"

# DaData — организация по ИНН/ОГРН: https://dadata.ru/api/find-party/
# В ЛК DaData для токена должны быть включены «Подсказки» (SUGGESTIONS)
DADATA_API_KEY=""
DADATA_SECRET_KEY=""
